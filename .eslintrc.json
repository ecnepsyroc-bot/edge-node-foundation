{
  "env": {
    "node": true,
    "es2021": true,
    "browser": false
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "commonjs"
  },
  "rules": {
    "indent": ["error", 2],
    "linebreak-style": ["error", "unix"],
    "quotes": ["error", "single", { "avoidEscape": true }],
    "semi": ["error", "always"],
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "prefer-const": "warn",
    "no-var": "error"
  },
  "overrides": [
    {
      "files": ["leaves/ui/**/*.js"],
      "env": {
        "browser": true,
        "node": false
      },
      "globals": {
        "compromise": "readonly",
        "nlp": "readonly",
        "WebSocket": "readonly"
      }
    }
  ]
}
